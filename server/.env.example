# =========================
# Required in production
# =========================
# Option A: full connection string (recommended)
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority

# Option B: build Atlas URI from parts (must match your cluster host pattern in server.js)
MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password
MONGODB_CLUSTER=your_cluster
MONGODB_DATABASE=your_database
JWT_SECRET=your_jwt_secret
PORT=3000
NODE_ENV=development
# Frontend domain (for CORS and email links back to the website)
CLIENT_URL=http://localhost:5173
SECONDARY_URL=http://localhost:3000
# Public URL of this API (used in verification email links). Defaults to http://localhost:PORT if unset.
API_PUBLIC_URL=http://localhost:3000
# Resend (https://resend.com) — rotate by changing this value only
RESEND_API_KEY=
# Must be a sender/domain you verified in Resend, e.g. PetGround <onboarding@resend.dev>
RESEND_FROM=PetGround <onboarding@resend.dev>

# =========================
# Optional / legacy fields
# =========================
# Optional: legacy Gmail (no longer used when RESEND_API_KEY is set)
EMAIL_USER=your_email
EMAIL_PASS=your_password

# Optional debug flags (keep disabled in production)
ENABLE_MORGAN=0
DEBUG_HTTP=0
DEBUG_HTTP_HEADERS=0
